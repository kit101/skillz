# mcp-email environment variables
# doc see: https://github.com/TimeCyber/email-mcp/blob/43a39bd84670855472b4518d44758cd95f4014eb/CONFIG_GUIDE.md
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_password
EMAIL_TYPE=exmail

# qwen-code authentication
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# test environment variables
TEST_HOSTNAME=example.com
TEST_RECIPIENT_EMAIL=your_email@x****x.com
